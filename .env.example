# =============================================================================
# AI Employee Vault — Environment Configuration (EXAMPLE)
# =============================================================================
# IMPORTANT: Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Gmail API Configuration
# -----------------------------------------------------------------------------
# Get these from Google Cloud Console: https://console.cloud.google.com/
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REFRESH_TOKEN=your_refresh_token_here
GMAIL_REDIRECT_URI=https://developers.google.com/oauthplayground

# -----------------------------------------------------------------------------
# Bank API Configuration
# -----------------------------------------------------------------------------
# For payment verification and account balance checks
BANK_API_TOKEN=your_bank_api_token_here
BANK_API_URL=https://api.yourbank.com/v1

# -----------------------------------------------------------------------------
# WhatsApp Session Configuration
# -----------------------------------------------------------------------------
# Path to WhatsApp Web session data
WHATSAPP_SESSION_PATH=./Secrets/whatsapp_session

# -----------------------------------------------------------------------------
# Odoo Configuration
# -----------------------------------------------------------------------------
# For accounting and invoice management
ODOO_URL=https://your-company.odoo.com
ODOO_API_KEY=your_odoo_api_key_here
ODOO_DATABASE=your_database_name

# -----------------------------------------------------------------------------
# Safety & Rate Limits
# -----------------------------------------------------------------------------
# DRY_RUN=true means actions are simulated but not executed
# Set to false for production use (after testing)
DRY_RUN=true

# Maximum emails the AI can send per hour (0 = unlimited, not recommended)
MAX_EMAILS_PER_HOUR=10

# Maximum payments the AI can process per hour (0 = unlimited, not recommended)
MAX_PAYMENTS_PER_HOUR=3

# Maximum amount per single transaction without explicit approval ($)
MAX_TRANSACTION_AMOUNT=500

# -----------------------------------------------------------------------------
# Claude API Configuration (if using Claude instead of local)
# -----------------------------------------------------------------------------
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-sonnet-4-5-20250929
CLAUDE_MAX_TOKENS=4096

# -----------------------------------------------------------------------------
# Social Media API Configuration
# -----------------------------------------------------------------------------
# LinkedIn
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token

# Twitter/X
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_token_secret

# Facebook/Instagram (Meta)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_meta_access_token

# -----------------------------------------------------------------------------
# Calendar Configuration
# -----------------------------------------------------------------------------
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com
GOOGLE_CALENDAR_CLIENT_ID=your_google_calendar_client_id
GOOGLE_CALENDAR_CLIENT_SECRET=your_google_calendar_client_secret

# -----------------------------------------------------------------------------
# System Configuration
# -----------------------------------------------------------------------------
# Path to the Obsidian vault
VAULT_PATH=./

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable/disable specific watchers
ENABLE_GMAIL_WATCHER=true
ENABLE_WHATSAPP_WATCHER=true
ENABLE_FILESYSTEM_WATCHER=true
ENABLE_FINANCE_WATCHER=true

# Enable/disable MCP servers
ENABLE_EMAIL_MCP=true
ENABLE_BROWSER_MCP=true
ENABLE_CALENDAR_MCP=true

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# Audit logging enabled
AUDIT_LOGGING=true

# Session timeout in minutes
SESSION_TIMEOUT=60

# IP whitelist for API access (comma-separated, empty = all)
IP_WHITELIST=

# Enable two-factor authentication for approvals
ENABLE_2FA_APPROVAL=false

# -----------------------------------------------------------------------------
# Notification Configuration
# -----------------------------------------------------------------------------
# Email address for system notifications
ADMIN_EMAIL=admin@yourcompany.com

# Slack webhook for alerts (optional)
SLACK_WEBHOOK_URL=

# SMS number for critical alerts (via Twilio or similar)
CRITICAL_ALERT_PHONE=

# -----------------------------------------------------------------------------
# Subscription Audit Configuration
# -----------------------------------------------------------------------------
# Flag subscriptions for review if cost exceeds this amount monthly ($)
SUBSCRIPTION_ALERT_THRESHOLD=100

# Flag if subscription hasn't been used in this many days
SUBSCRIPTION_UNUSED_DAYS=30

# Flag if cost increased by more than this percentage month-over-month
SUBSCRIPTION_INCREASE_THRESHOLD=0.20

# -----------------------------------------------------------------------------
# SLA Configuration (in hours)
# -----------------------------------------------------------------------------
SLA_P0_CRITICAL=1
SLA_P1_HIGH=4
SLA_P2_MEDIUM=24
SLA_P3_LOW=72

# -----------------------------------------------------------------------------
# Approval Configuration
# -----------------------------------------------------------------------------
# Auto-approve threshold for known contacts (0 = always approve)
AUTO_APPROVE_KNOWN_CONTACT_THRESHOLD=50

# Approval expiry in hours (approvals expire if not actioned)
APPROVAL_EXPIRY_HOURS=48

# Require approval for new payees (true/false)
REQUIRE_APPROVAL_NEW_PAYEES=true
